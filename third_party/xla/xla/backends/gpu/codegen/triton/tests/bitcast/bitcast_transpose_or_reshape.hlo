// RUN: hlo_to_xtileir %s | FileCheck %s
// RUN: triton_test_correctness %s

// RUN: hlo_to_xtileir %s --use_experimental_tiling | FileCheck %s
// RUN: triton_test_correctness %s --xla_gpu_experimental_enable_tiling_propagation

fusion {
  p = s8[1,1024]{1,0} parameter(0)
  ROOT bitcast = s8[1024,1]{0,1} bitcast(p)
}

// CHECK: tt.trans

ENTRY main {
  p = s8[1,1024]{1,0} parameter(0)
  ROOT fusion = s8[1024,1]{0,1} fusion(p), kind=kCustom, calls=fusion,
    backend_config={
      "fusion_backend_config":{
      "kind":"__triton",
      "block_level_fusion_config":{
        "output_tiles":[{"sizes":["8","1"]}],
        "num_warps":"1",
        "num_ctas":"1",
        "num_stages":"1"}}}
}
