// RUN: hlo_to_xtileir %s | FileCheck %s
// RUN: triton_test_correctness %s

fusion {
  p0 = f32[1,1,1,1] parameter(0)
  p1 = f32[1] parameter(1)
  reshape1 = f32[] reshape(p0)
  reshape2 = f32[] reshape(p1)
  ROOT add_op = f32[] add(reshape1, reshape2)
}
// CHECK:     tt.reshape
// CHECK:     tt.reduce{{.*}}axis = 0
// CHECK-NOT: tt.reshape
// CHECK:     tt.reduce{{.*}}axis = 0
// CHECK:     xtile.insert {{.*}} : tensor<f32>

ENTRY main {
  p0 = f32[1,1,1,1] parameter(0)
  p1 = f32[1] parameter(1)
  ROOT fusion = f32[] fusion(p0, p1), kind=kCustom, calls=fusion,
    backend_config={
      "fusion_backend_config":{
        "kind":"__triton",
        "block_level_fusion_config":{
          "output_tiles": [{"sizes":[]}],
          "num_warps":"1",
          "num_ctas":"1",
          "num_stages":"1"}}}
}
