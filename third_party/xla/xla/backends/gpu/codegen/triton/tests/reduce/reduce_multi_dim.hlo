// RUN: hlo_to_xtileir --xla_gpu_experimental_enable_tiling_propagation %s | FileCheck %s
// RUN: triton_test_correctness --xla_gpu_experimental_enable_tiling_propagation --abs_error_bound=1e-4 --rel_error_bound=1e-4 %s

region {
  p0 = f32[] parameter(0)
  p1 = f32[] parameter(1)
  ROOT add = f32[] add(p0, p1)
}

fusion {
  p = f32[8,16,12,32,16] parameter(0)
  c = f32[] constant(0)
  ROOT reduce = f32[16,32] reduce(p, c), dimensions={0,2,4}, to_apply=region,
    backend_config={sizes:[2,4,8]}
}

ENTRY main {
  p = f32[8,16,12,32,16] parameter(0)
  ROOT fusion = f32[16,32] fusion(p), kind=kCustom, calls=fusion,
    backend_config={
      "fusion_backend_config":{
        "kind":"__triton",
        "block_level_fusion_config":{
          "output_tiles":[{"sizes":["8", "16"]}],
          "num_warps":"1",
          "num_ctas":"1",
          "num_stages":"1"}}}
}

// CHECK-DAG:  %[[C0:.*]] = arith.constant 0 : index
// CHECK-DAG:  %[[C2:.*]] = arith.constant 2 : index
// CHECK-DAG:  %[[C3:.*]] = arith.constant 3 : index
// CHECK-DAG:  %[[C4:.*]] = arith.constant 4 : index
// CHECK-DAG:  %[[C1:.*]] = arith.constant 1 : index
// CHECK-DAG:  %[[INIT:.*]] = arith.constant dense<0.000000e+00> : tensor<2x8x4x16x8xf32>
// CHECK:      %[[FOR1:.*]] = scf.for %[[IV1:.*]] = %[[C0]] to %[[C4]] step %[[C1]] iter_args(%[[ACC1:.*]] = %[[INIT]]) -> (tensor<2x8x4x16x8xf32>) {
// CHECK:        %[[FOR2:.*]] = scf.for %[[IV2:.*]] = %[[C0]] to %[[C3]] step %[[C1]] iter_args(%[[ACC2:.*]] = %[[ACC1]]) -> (tensor<2x8x4x16x8xf32>) {
// CHECK:          %[[FOR3:.*]] = scf.for %[[IV3:.*]] = %[[C0]] to %[[C2]] step %[[C1]] iter_args(%[[ACC3:.*]] = %[[ACC2]]) -> (tensor<2x8x4x16x8xf32>) {
// CHECK:            %[[OFFSET_P0:.*]] = xla.apply_indexing
// CHECK:            %[[OFFSET_P1:.*]] = xla.apply_indexing
// CHECK:            %[[OFFSET_P2:.*]] = xla.apply_indexing
// CHECK:            %[[OFFSET_P3:.*]] = xla.apply_indexing
// CHECK:            %[[OFFSET_P4:.*]] = xla.apply_indexing
// CHECK:            %[[EXTRACT:.*]] = xtile.extract %{{.*}}[%[[OFFSET_P0]], %[[OFFSET_P1]], %[[OFFSET_P2]], %[[OFFSET_P3]], %[[OFFSET_P4]]] [2, 8, 4, 16, 8]
// CHECK:            %[[COMBINE:.*]] = arith.addf %[[ACC3]], %[[EXTRACT]] : tensor<2x8x4x16x8xf32>
// CHECK:            scf.yield %[[COMBINE]] : tensor<2x8x4x16x8xf32>
// CHECK:          }
// CHECK:          scf.yield %[[FOR3]] : tensor<2x8x4x16x8xf32>
// CHECK:        }
// CHECK:        scf.yield %[[FOR2]] : tensor<2x8x4x16x8xf32>
// CHECK:      }
// CHECK:      %[[REDUCE3:.*]] = "tt.reduce"(%[[FOR1]]) <{axis = 4 : i32}>
// CHECK:      %[[REDUCE2:.*]] = "tt.reduce"(%[[REDUCE3]]) <{axis = 2 : i32}>
// CHECK:      %[[REDUCE1:.*]] = "tt.reduce"(%[[REDUCE2]]) <{axis = 0 : i32}>
