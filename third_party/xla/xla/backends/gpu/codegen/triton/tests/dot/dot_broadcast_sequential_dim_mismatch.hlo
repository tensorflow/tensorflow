// RUN: (hlo_to_xtileir %s --xla_gpu_experimental_enable_tiling_propagation || true) 2>&1 | FileCheck %s --check-prefix=CHECK-ERROR
// CHECK-ERROR: Sequential dim id 3 not found in the induction var map.

fusion {
  p0 = f32[16,32]{1,0} parameter(0)
  p1 = f32[32,16]{1,0} parameter(1)
  dot = f32[16,16]{1,0} dot(p0, p1),
    lhs_contracting_dims={1}, rhs_contracting_dims={0},
    backend_config={sizes:[16]}
  ROOT broadcast = f32[2,16,16]{2,1,0} broadcast(dot), dimensions={1,2}
}

ENTRY main {
  p0 = f32[16,32]{1,0} parameter(0)
  p1 = f32[32,16]{1,0} parameter(1)
  ROOT fusion = f32[2,16,16]{2,1,0} fusion(p0, p1), kind=kCustom, calls=fusion,
    backend_config={
      "fusion_backend_config":{
        "kind":"__triton",
        "block_level_fusion_config":{
          "output_tiles":[{"sizes":["1","16","16"]}],
          "num_warps":"1",
          "num_ctas":"1",
          "num_stages":"1"}}}
}
