// RUN: hlo_to_xtileir %s | FileCheck %s --check-prefixes=CHECK,CHECK-OLD
// RUN: triton_test_correctness %s

// RUN: hlo_to_xtileir %s --use_experimental_tiling | FileCheck %s --check-prefixes=CHECK,CHECK-NEW
// RUN: triton_test_correctness %s --xla_gpu_experimental_enable_tiling_propagation

fusion {
  p = f32[64]{0} parameter(0)
  ROOT bitcast = f32[8,8]{1,0} bitcast(p)
}

// CHECK-OLD: #[[$ATTR_0:.+]] = #xla.indexing_map<"(pid_0) -> (pid_0 * 4), domain: pid_0 in [0, 15]">
// CHECK-OLD: #[[$ATTR_1:.+]] = #xla.indexing_map<"(pid_0) -> (pid_0 floordiv 2), domain: pid_0 in [0, 15]">
// CHECK-OLD: #[[$ATTR_2:.+]] = #xla.indexing_map<"(pid_0) -> ((pid_0 mod 2) * 4), domain: pid_0 in [0, 15]">

// CHECK-NEW: #[[$ATTR_0:.+]] = #xla.indexing_map<"(pid) -> (pid * 4), domain: pid in [0, 15]">
// CHECK-NEW: #[[$ATTR_1:.+]] = #xla.indexing_map<"(pid) -> (pid floordiv 2), domain: pid in [0, 15]">
// CHECK-NEW: #[[$ATTR_2:.+]] = #xla.indexing_map<"(pid) -> ((pid mod 2) * 4), domain: pid in [0, 15]">

// CHECK-LABEL:   xtile.entry_func @triton_fn(
// CHECK-SAME:      %[[ARG0:.*]]: memref<64xf32>,
// CHECK-SAME:      %[[ARG1:.*]]: memref<8x8xf32>,
// CHECK-SAME:      %[[ARG2:.*]]: index) attributes {num_opaque_args = 0 : i32} {
// CHECK:           %[[APPLY_INDEXING_0:.*]] = xla.apply_indexing #[[$ATTR_0]](%[[ARG2]])
// CHECK:           %[[EXTRACT_0:.*]] = xtile.extract %[[ARG0]]{{\[}}%[[APPLY_INDEXING_0]]] [4] [1] : memref<64xf32> -> tensor<4xf32>
// CHECK:           %[[RESHAPE_0:.*]] = tt.reshape %[[EXTRACT_0]] : tensor<4xf32> -> tensor<1x4xf32>
// CHECK:           %[[APPLY_INDEXING_1:.*]] = xla.apply_indexing #[[$ATTR_1]](%[[ARG2]])
// CHECK:           %[[APPLY_INDEXING_2:.*]] = xla.apply_indexing #[[$ATTR_2]](%[[ARG2]])
// CHECK:           xtile.insert %[[RESHAPE_0]] into %[[ARG1]]{{\[}}%[[APPLY_INDEXING_1]], %[[APPLY_INDEXING_2]]] [1, 4] [1, 1] : tensor<1x4xf32> -> memref<8x8xf32>
// CHECK:           xtile.return
// CHECK:         }

ENTRY main {
  p = f32[64]{0} parameter(0)
  ROOT fusion = f32[8,8]{1,0} fusion(p), kind=kCustom, calls=fusion,
    backend_config={
    "fusion_backend_config":{
      "kind":"__triton",
      "block_level_fusion_config":{
        "output_tiles":[{"sizes":["1","4"]}],
        "num_warps":"1",
        "num_ctas":"1",
        "num_stages":"1"}}}
}
