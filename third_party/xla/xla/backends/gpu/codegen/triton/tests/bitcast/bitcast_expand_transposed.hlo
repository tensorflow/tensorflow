// RUN: hlo_to_xtileir %s --xla_gpu_experimental_enable_tiling_propagation | FileCheck %s
// RUN: triton_test_correctness %s --xla_gpu_experimental_enable_tiling_propagation

fusion {
  p = f32[64,16]{1,0} parameter(0)
  ROOT bitcast = f32[1,16,64]{1,0,2} bitcast(p)
}

// CHECK-DAG: #indexing_map = #xla.indexing_map<"(pid) -> ((pid mod 16) * 4), domain: pid in [0, 63]">
// CHECK-DAG: #indexing_map1 = #xla.indexing_map<"(pid) -> ((pid / 16) * 4), domain: pid in [0, 63]">

// CHECK-LABEL:  xtile.entry_func @triton_fn(
// CHECK-SAME:     %[[ARG0:.*]]: memref<64x16xf32>,
// CHECK-SAME:     %[[ARG1:.*]]: memref<1x16x64xf32, #xtile.layout<[1, 0, 2]>>,
// CHECK-SAME:     %[[ARG2:.*]]: index)
// CHECK:          %[[C0:.*]] = arith.constant 0 : index
// CHECK:          %[[INDEX0:.*]] = xla.apply_indexing #indexing_map(%[[ARG2]])
// CHECK:          %[[INDEX1:.*]] = xla.apply_indexing #indexing_map1(%[[ARG2]])
// CHECK:          %[[EXTRACT:.*]] = xtile.extract %[[ARG0]][%[[INDEX0]], %[[INDEX1]]] [4, 4] [1, 1] : memref<64x16xf32> -> tensor<4x4xf32>
// CHECK:          %[[EXPAND:.*]] = tt.expand_dims %[[EXTRACT]] {axis = 1 : i32} : tensor<4x4xf32> -> tensor<4x1x4xf32>
// CHECK:          %[[BROADCAST:.*]] = tt.broadcast %[[EXPAND]] : tensor<4x1x4xf32> -> tensor<4x2x4xf32>
// CHECK:          %[[TRANSPOSE:.*]] = tt.trans %[[BROADCAST]] {order = array<i32: 1, 2, 0>} : tensor<4x2x4xf32> -> tensor<2x4x4xf32>
// CHECK:          xtile.insert %[[TRANSPOSE]] into %[[ARG1]][%[[C0]], %[[INDEX1]], %[[INDEX0]]] [2, 4, 4] [1, 1, 1] : tensor<2x4x4xf32> -> memref<1x16x64xf32, #xtile.layout<[1, 0, 2]>>
// CHECK:          xtile.return

ENTRY main {
  p = f32[64,16]{1,0} parameter(0)
  ROOT fusion = f32[1,16,64]{1,0,2} fusion(p), kind=kCustom, calls=fusion,
    backend_config={
    "fusion_backend_config":{
      "kind":"__triton",
      "block_level_fusion_config":{
        "output_tiles":[{"sizes":[2,4,4]}],
        "num_warps":"1",
        "num_ctas":"1",
        "num_stages":"1"}}}
}
