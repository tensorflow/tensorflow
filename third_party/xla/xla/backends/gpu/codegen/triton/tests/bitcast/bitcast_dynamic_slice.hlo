// RUN: hlo_to_xtileir %s | FileCheck %s
// RUN: triton_test_correctness %s

// RUN: hlo_to_xtileir %s --xla_gpu_experimental_enable_tiling_propagation | FileCheck %s
// RUN: triton_test_correctness %s --xla_gpu_experimental_enable_tiling_propagation
HloModule m

triton_softmax_computation (p0: f32[1024, 16], offset: s32[]) -> f32[8192] {
  p0 = f32[1024, 16]{1,0} parameter(0)
  offset = s32[] parameter(1)
  dynamic_slice = f32[512,16]{1,0} dynamic-slice(p0, offset, offset), dynamic_slice_sizes={512, 16}
  ROOT bitcast = f32[8192]{0} bitcast(dynamic_slice)
}

// CHECK: #[[$ATTR_0:.+]] = #xla.indexing_map<"([[PID:pid(_0)?]], d1) -> ([[PID]] floordiv 2 + d1), domain: [[PID]] in [0, 1023], d1 in [0, 512]">
// CHECK: #[[$ATTR_1:.+]] = #xla.indexing_map<"([[PID]]) -> (([[PID]] mod 2) * 8), domain: [[PID]] in [0, 1023]">
// CHECK: #[[$ATTR_2:.+]] = #xla.indexing_map<"([[PID]]) -> ([[PID]] * 8), domain: [[PID]] in [0, 1023]">
// CHECK-LABEL:   xtile.entry_func @triton_fn(
// CHECK-SAME:      %[[ARG0:.*]]: memref<1024x16xf32>,
// CHECK-SAME:      %[[ARG1:.*]]: memref<i32>,
// CHECK-SAME:      %[[ARG2:.*]]: memref<8192xf32>,
// CHECK-SAME:      %[[ARG3:.*]]: index) attributes {num_opaque_args = 0 : i32} {
// CHECK:           %[[CONSTANT_0:.*]] = arith.constant 512 : i32
// CHECK:           %[[CONSTANT_1:.*]] = arith.constant 0 : i32
// CHECK:           %[[EXTRACT_0:.*]] = xtile.extract %[[ARG1]][] [] [] : memref<i32> -> tensor<i32>
// CHECK:           %[[EXTRACT_1:.*]] = tensor.extract %[[EXTRACT_0]][] : tensor<i32>
// CHECK:           %[[MAXSI_0:.*]] = arith.maxsi %[[EXTRACT_1]], %[[CONSTANT_1]] : i32
// CHECK:           %[[MINSI_0:.*]] = arith.minsi %[[MAXSI_0]], %[[CONSTANT_0]] : i32
// CHECK:           %[[INDEX_CAST_0:.*]] = arith.index_cast %[[MINSI_0]] : i32 to index
// CHECK:           %[[APPLY_INDEXING_0:.*]] = xla.apply_indexing #[[$ATTR_0]](%[[ARG3]], %[[INDEX_CAST_0]])
// CHECK:           %[[APPLY_INDEXING_1:.*]] = xla.apply_indexing #[[$ATTR_1]](%[[ARG3]])
// CHECK:           %[[EXTRACT_2:.*]] = xtile.extract %[[ARG0]][%[[APPLY_INDEXING_0]], %[[APPLY_INDEXING_1]]] [1, 8] [1, 1] : memref<1024x16xf32> -> tensor<1x8xf32>
// CHECK:           %[[RESHAPE_0:.*]] = tt.reshape %[[EXTRACT_2]] : tensor<1x8xf32> -> tensor<8xf32>
// CHECK:           %[[APPLY_INDEXING_2:.*]] = xla.apply_indexing #[[$ATTR_2]](%[[ARG3]])
// CHECK:           xtile.insert %[[RESHAPE_0]] into %[[ARG2]][%[[APPLY_INDEXING_2]]] [8] [1] : tensor<8xf32> -> memref<8192xf32>
// CHECK:           xtile.return
// CHECK:         }


ENTRY main {
  p0 = f32[1024, 16]{1,0} parameter(0)
  offset = s32[] parameter(1)
  ROOT triton_softmax = f32[8192]{0} fusion(p0, offset), kind=kCustom, calls=triton_softmax_computation,
    backend_config={
    "fusion_backend_config":{
      "kind":"__triton",
      "block_level_fusion_config":{
        "output_tiles":[{"sizes":["8"]}],
        "num_warps":"8",
        "num_ctas":1,
        "num_stages":1}}}
}
