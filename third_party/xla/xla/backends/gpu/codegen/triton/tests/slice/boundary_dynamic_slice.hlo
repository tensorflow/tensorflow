// RUN: hlo_to_xtileir --xla_gpu_experimental_enable_tiling_propagation=false %s | FileCheck %s
// RUN: triton_test_correctness --xla_gpu_experimental_enable_tiling_propagation=false %s

// RUN: hlo_to_xtileir %s --xla_gpu_experimental_enable_tiling_propagation | FileCheck %s
// RUN: triton_test_correctness %s --xla_gpu_experimental_enable_tiling_propagation

max {
  x = f32[] parameter(0)
  y = f32[] parameter(1)
  ROOT maximum = f32[] maximum(x, y)
}

fusion {
  p0 = f32[2, 97] parameter(0)
  constant = f32[] constant(-inf)
  ROOT reduce = f32[2] reduce(p0, constant), dimensions={1}, to_apply=max
}

ENTRY main {
  input = f32[10, 100] parameter(0)
  offset0 = s32[] parameter(1)
  offset1 = s32[] parameter(2)
  dynamic_slice = f32[2, 97] dynamic-slice(input, offset0, offset1), dynamic_slice_sizes={2, 97}
  ROOT triton_fusion = f32[2] fusion(dynamic_slice), kind=kCustom, calls=fusion,
    backend_config={
    "fusion_backend_config":{
      "kind":"__triton",
      "block_level_fusion_config":{
        "output_tiles":[{"sizes":["1"]}],
        "num_warps":"1",
        "num_ctas":1,
        "num_stages":1}}}
}

// CHECK-LABEL:   xtile.entry_func @triton_fn(
// CHECK-SAME:      %[[ARG0:.*]]: memref<2x97xf32>,
// CHECK-SAME:      %[[ARG1:.*]]: memref<2xf32>,
// CHECK-SAME:      %[[ARG2:.*]]: index)
// CHECK:           %[[CST:.*]] = arith.constant 0xFF800000 : f32
// CHECK:           %[[C0:.*]] = arith.constant 0 : index
// CHECK:           %[[EXTRACT:.*]] = xtile.extract %[[ARG0]][%[[ARG2]], %[[C0]]] [1, 128] [1, 1] : memref<2x97xf32> -> tensor<1x128xf32>
// CHECK:           %[[MASK:.*]] = xtile.mask %[[EXTRACT]] bounds [1, 97], %[[CST]] : tensor<1x128xf32>
// CHECK:           %[[REDUCE:.*]] = "tt.reduce"(%[[MASK]]) <{axis = 1 : i32}> ({
// CHECK:           ^bb0(%{{.*}}: f32, %{{.*}}: f32):
// CHECK:             %[[MAX:.*]] = arith.maximumf %{{.*}}, %{{.*}} : f32
// CHECK:             tt.reduce.return %[[MAX]] : f32
// CHECK:           }) : (tensor<1x128xf32>) -> tensor<1xf32>
// CHECK:           xtile.insert %[[REDUCE]] into %[[ARG1]][%[[ARG2]]] [1] [1] : tensor<1xf32> -> memref<2xf32>
// CHECK:           xtile.return
