// RUN: hlo_to_xtileir %s --xla_gpu_experimental_enable_tiling_propagation | FileCheck %s

fusion {
  p0 = f32[4,8] parameter(0)
  p1 = f32[8,16] parameter(1)
  dot = f32[4,16] dot(p0, p1), lhs_contracting_dims={1}, rhs_contracting_dims={0}
  ROOT mul = f32[4,16] multiply(dot, dot)
}

// CHECK-LABEL:   xtile.entry_func @triton_fn(
// CHECK-SAME:      %[[ARG0:.*]]: memref<4x8xf32>,
// CHECK-SAME:      %[[ARG1:.*]]: memref<8x16xf32>,
// CHECK-SAME:      %[[ARG2:.*]]: memref<4x16xf32>,
// CHECK-SAME:      %[[ARG3:.*]]: index)
// CHECK-DAG:       %[[CST:.*]] = arith.constant dense<0.000000e+00> : tensor<1x2xf32>
// CHECK-DAG:       %[[C0:.*]] = arith.constant 0 : index
// CHECK:           %[[APPLY_IDX0:.*]] = xla.apply_indexing #indexing_map(%[[ARG3]])
// CHECK:           %[[EXTRACT0:.*]] = xtile.extract %[[ARG0]][%[[APPLY_IDX0]], %[[C0]]] [1, 8] [1, 1] : memref<4x8xf32> -> tensor<1x8xf32>
// CHECK:           %[[APPLY_IDX1:.*]] = xla.apply_indexing #indexing_map1(%[[ARG3]])
// CHECK:           %[[EXTRACT1:.*]] = xtile.extract %[[ARG1]][%[[C0]], %[[APPLY_IDX1]]] [8, 2] [1, 1] : memref<8x16xf32> -> tensor<8x2xf32>
// CHECK:           %[[DOT:.*]] = tt.dot %[[EXTRACT0]], %[[EXTRACT1]], %[[CST]], inputPrecision = tf32 : tensor<1x8xf32> * tensor<8x2xf32> -> tensor<1x2xf32>
// CHECK:           %[[MUL:.*]] = arith.mulf %[[DOT]], %[[DOT]] : tensor<1x2xf32>
// CHECK:           xtile.insert %[[MUL]] into %[[ARG2]][%[[APPLY_IDX0]], %[[APPLY_IDX1]]] [1, 2] [1, 1] : tensor<1x2xf32> -> memref<4x16xf32>
// CHECK:           xtile.return

ENTRY main {
  p0 = f32[4,8] parameter(0)
  p1 = f32[8,16] parameter(1)
  ROOT triton_fusion = f32[4,16] fusion(p0, p1), kind=kCustom, calls=fusion,
    backend_config={
    "fusion_backend_config":{
      "kind":"__triton",
      "block_level_fusion_config":{
        "output_tiles":[{"sizes":["1", "2"]}],
        "num_warps":"1",
        "num_ctas":1,
        "num_stages":1}}}
}
