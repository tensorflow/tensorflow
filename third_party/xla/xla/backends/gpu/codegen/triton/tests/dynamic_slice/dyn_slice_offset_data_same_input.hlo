// RUN: hlo_to_xtileir %s | FileCheck %s
// RUN: triton_test_correctness %s

// RUN: hlo_to_xtileir %s --use_experimental_tiling | FileCheck %s
// RUN: triton_test_correctness %s --xla_gpu_experimental_enable_tiling_propagation

fusion {
  p0 = s32[64] parameter(0)
  slice1 = s32[1] slice(p0), slice={[0:1]}
  off = s32[] reshape(slice1)
  ROOT r = s32[10] dynamic-slice(p0, off), dynamic_slice_sizes={10}
}
// CHECK-LABEL:   xtile.entry_func @triton_fn(
// CHECK-SAME:      %[[ARG0:[A-Za-z0-9]+]]: memref<64xi32>,
// CHECK-SAME:      %[[ARG1:[A-Za-z0-9]+]]: memref<10xi32>,
// CHECK-SAME:      %[[PID:[A-Za-z0-9]+]]: index) attributes {num_opaque_args = 0 : i32}

// CHECK-DAG: %[[C54_I32:.*]] = arith.constant 54 : i32
// CHECK-DAG: %[[C0_I32:.*]] = arith.constant 0 : i32
// CHECK-DAG: %[[C0:.*]] = arith.constant 0 : index

// CHECK:     %[[EXTRACT_0:.*]] = xtile.extract %[[ARG0]][%[[C0]]] [1]
// CHECK-SAME:   memref<64xi32> -> tensor<1xi32>

// CHECK:      %[[VAL_0:.*]] = tt.unsplat %[[EXTRACT_0]] : tensor<1xi32>
// CHECK:      %[[MAXSI_0:.*]] = arith.maxsi %[[VAL_0]], %[[C0_I32]] : i32
// CHECK:      %[[MINSI_0:.*]] = arith.minsi %[[MAXSI_0]], %[[C54_I32]] : i32
// CHECK:      %[[CAST:.*]] = arith.index_cast %[[MINSI_0]] : i32 to index
// CHECK:      %[[EXTRACT_0:.*]] = xtile.extract %[[ARG0]][%[[CAST]]] [32]
// CHECK-SAME:   memref<64xi32> -> tensor<32xi32>
// CHECK:      xtile.insert %[[EXTRACT_0]] into %[[ARG1]][%[[C0]]] [32]
// CHECK-SAME:   : tensor<32xi32> -> memref<10xi32>

ENTRY main {
  p0 = s32[64] parameter(0)
  ROOT fusion = s32[10] fusion(p0), kind=kCustom, calls=fusion,
    backend_config={"fusion_backend_config":{"kind":"__triton",
      "block_level_fusion_config":{
      "output_tiles":[{"sizes":["32"]}],
        "num_warps":1,"num_ctas":1,"num_stages":1}}}
}
