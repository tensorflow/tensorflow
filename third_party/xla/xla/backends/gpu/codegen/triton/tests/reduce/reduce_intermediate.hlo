// RUN: hlo_to_xtileir %s | FileCheck %s
// RUN: triton_test_correctness %s
// RUN: hlo_to_xtileir --xla_gpu_experimental_enable_tiling_propagation %s | FileCheck %s
// RUN: triton_test_correctness --xla_gpu_experimental_enable_tiling_propagation %s

maximum {
  p0 = f32[] parameter(0)
  p1 = f32[] parameter(1)
  ROOT maximum = f32[] maximum(p0, p1)
}

fusion {
  p = f32[5,5,5,5,3] parameter(0)
  c = f32[] constant(0)
  ROOT reduction = f32[5,5,5,3] reduce(p, c), dimensions={2}, to_apply=maximum
}
// CHECK:  xtile.mask
// CHECK:  "tt.reduce"(%[[SELECT:.*]]) <{axis = 2 : i32}>

ENTRY main {
  p = f32[5,5,5,5,3] parameter(0)
  ROOT triton_reduction = f32[5,5,5,3] fusion(p), kind=kCustom,
    calls=fusion,
    backend_config={
      "fusion_backend_config":{
      "kind":"__triton",
      "block_level_fusion_config":{
        "output_tiles":[{"sizes":["4", "2", "5", "1"]}],
        "num_warps":"1",
        "num_ctas":"1",
        "num_stages":"1"}}}
}
