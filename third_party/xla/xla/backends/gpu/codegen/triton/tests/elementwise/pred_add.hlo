// RUN: hlo_to_xtileir %s | FileCheck %s
// RUN: triton_test_correctness %s

// RUN: hlo_to_xtileir %s --xla_gpu_experimental_enable_tiling_propagation | FileCheck %s
// RUN: triton_test_correctness %s --xla_gpu_experimental_enable_tiling_propagation

fusion {
  param_0 = pred[] parameter(0)
  param_1 = pred[] parameter(1)
  ROOT add = pred[] add(param_0, param_1)
}
// CHECK: arith.ori {{.*}} : i1

ENTRY main {
  c0 = pred[] constant(1)
  c1 = pred[] constant(1)
  ROOT add = pred[] fusion(c0, c1), kind=kCustom, calls=fusion,
    backend_config={"fusion_backend_config":{
      "kind":"__triton",
      "block_level_fusion_config":{
        "num_warps":"1","output_tiles":[{"sizes":[]}],
        "num_ctas":1,"num_stages":1,"is_tma_allowed":false}}}
}
