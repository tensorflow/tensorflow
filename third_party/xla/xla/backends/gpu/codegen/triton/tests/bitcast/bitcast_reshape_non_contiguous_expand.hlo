// RUN: hlo_to_xtileir %s --xla_gpu_experimental_enable_tiling_propagation 2>&1 | FileCheck %s --check-prefix=CHECK-ERROR
// CHECK-ERROR: UNIMPLEMENTED: Unsupported minimal reshape [0, 1] -> [0, 2] (kExpandShape): Source tiles must be contiguous.

fusion {
  p = f32[32,4]{1,0} parameter(0)
  bitcast = f32[128]{0} bitcast(p)
  ROOT slice = f32[32]{0} slice(bitcast), slice={[0:128:4]}
}

ENTRY main {
  p = f32[32,4]{1,0} parameter(0)
  ROOT fusion = f32[32]{0} fusion(p), kind=kCustom, calls=fusion,
    backend_config={
    "fusion_backend_config":{
      "kind":"__triton",
      "block_level_fusion_config":{
        "output_tiles":[{"sizes":["16"]}],
        "num_warps":"1",
        "num_ctas":"1",
        "num_stages":"1"}}}
}
