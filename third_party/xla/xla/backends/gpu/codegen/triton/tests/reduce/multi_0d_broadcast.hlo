// RUN: hlo_to_xtileir %s | FileCheck %s
// RUN: triton_test_correctness %s --abs_error_bound=1e-1 --rel_error_bound=1e-1
// TODO: b/502907772 - enable experimental tiling after fixing crash.
// RUN-NOT: hlo_to_xtileir --xla_gpu_experimental_enable_tiling_propagation %s | FileCheck %s
// RUN-NOT: triton_test_correctness %s --xla_gpu_experimental_enable_tiling_propagation

add {
  p0 = f32[] parameter(0)
  p1 = f32[] parameter(1)
  ROOT add = f32[] add(p0, p1)
}

fusion {
  p = f32[] parameter(0)
  exp = f32[] exponential(p)
  b1 = f32[10] broadcast(exp), dimensions={}
  b2 = f32[10,10] broadcast(exp), dimensions={}
  b3 = f32[10,10] broadcast(b1), dimensions={0}
  add_op = f32[10,10] add(b2,b3)
  c = f32[] constant(0)
  reduce1 = f32[10] reduce(add_op, c), dimensions={0}, to_apply=add
  ROOT reduce2 = f32[] reduce(reduce1, c), dimensions={0}, to_apply=add
}
// CHECK:     xtile.extract {{.*}} -> tensor<f32>
// CHECK:     tt.splat
// CHECK:     arith.addf
// CHECK:     tt.reduce
// CHECK:     xtile.insert {{.*}} : tensor<f32>

ENTRY main {
  p = f32[] parameter(0)
  ROOT fusion = f32[] fusion(p), kind=kCustom, calls=fusion,
    backend_config={
      "fusion_backend_config":{
        "kind":"__triton",
        "block_level_fusion_config":{
          "output_tiles": [{"sizes":[]}],
          "num_warps":"1",
          "num_ctas":"1",
          "num_stages":"1"}}}
}
