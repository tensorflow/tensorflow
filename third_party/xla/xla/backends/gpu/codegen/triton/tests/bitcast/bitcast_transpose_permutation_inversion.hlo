// RUN: (hlo_to_xtileir %s --xla_gpu_experimental_enable_tiling_propagation || true) 2>&1 | FileCheck %s --check-prefix=CHECK-ERROR
// CHECK-ERROR: 'stablehlo.transpose' op inferred type(s) 'tensor<16x8x4x16xbf16>' are incompatible with return type(s) of operation 'tensor<16x4x8x16xbf16>'

fusion {
  p0 = bf16[8,16,16,4]{2,0,3,1} parameter(0)
  ROOT bitcast = bf16[16,4,8,16]{3,2,1,0} bitcast(p0)
}

ENTRY main {
  p0 = bf16[8,16,16,4]{2,0,3,1} parameter(0)
  ROOT fusion = bf16[16,4,8,16]{3,2,1,0} fusion(p0), kind=kCustom, calls=fusion,
    backend_config={
      "fusion_backend_config":{
        "kind":"__triton",
        "block_level_fusion_config":{
          "output_tiles":[{"sizes":["16","4","8","16"]}],
          "num_warps":"1",
          "num_ctas":"1",
          "num_stages":"1"}}}
}
