// RUN: hlo_to_xtileir --xla_gpu_experimental_enable_tiling_propagation=false %s | FileCheck %s
// RUN: triton_test_correctness --xla_gpu_experimental_enable_tiling_propagation=false %s --abs_error_bound=1e-4 --rel_error_bound=1e-6

// RUN: hlo_to_xtileir %s --xla_gpu_experimental_enable_tiling_propagation | FileCheck %s
// RUN: triton_test_correctness %s --xla_gpu_experimental_enable_tiling_propagation --abs_error_bound=1e-4 --rel_error_bound=1e-6

fusion {
  p0 = bf16[8,16,16,4]{2,0,3,1} parameter(0)
  ROOT bitcast = bf16[16,4,8,16]{3,2,1,0} bitcast(p0)
}

// CHECK: xtile.entry_func @triton_fn(
// CHECK-SAME: %[[ARG0:[^:]+]]: memref<8x16x16x4xbf16, #xtile.layout<[2, 0, 3, 1]>>,
// CHECK-SAME: %[[ARG1:[^:]+]]: memref<16x4x8x16xbf16>,
// CHECK-SAME: %[[PID:[^:]+]]: index)
// CHECK: %[[CONSTANT_0:.*]] = arith.constant 0 : index
// CHECK: %[[EXTRACT:.*]] = xtile.extract %[[ARG0]][%[[CONSTANT_0]], %[[CONSTANT_0]], %[[CONSTANT_0]], %[[CONSTANT_0]]] [8, 16, 16, 4] [1, 1, 1, 1] : memref<8x16x16x4xbf16, #xtile.layout<[2, 0, 3, 1]>> -> tensor<8x16x16x4xbf16>
// CHECK: %[[TRANSPOSE:.*]] = tt.trans %[[EXTRACT]] {order = array<i32: 1, 3, 0, 2>} : tensor<8x16x16x4xbf16> -> tensor<16x4x8x16xbf16>
// CHECK: xtile.insert %[[TRANSPOSE]] into %[[ARG1]][%[[CONSTANT_0]], %[[CONSTANT_0]], %[[CONSTANT_0]], %[[CONSTANT_0]]] [16, 4, 8, 16] [1, 1, 1, 1] : tensor<16x4x8x16xbf16> -> memref<16x4x8x16xbf16>
// CHECK: xtile.return

ENTRY main {
  p0 = bf16[8,16,16,4]{2,0,3,1} parameter(0)
  ROOT fusion = bf16[16,4,8,16]{3,2,1,0} fusion(p0), kind=kCustom, calls=fusion,
    backend_config={
      "fusion_backend_config":{
        "kind":"__triton",
        "block_level_fusion_config":{
          "output_tiles":[{"sizes":["16","4","8","16"]}],
          "num_warps":"1",
          "num_ctas":"1",
          "num_stages":"1"}}}
}
