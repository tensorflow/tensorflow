// RUN: hlo_to_xtileir %s | FileCheck %s
// RUN: triton_test_correctness %s
// RUN: hlo_to_xtileir --use_experimental_tiling %s | FileCheck %s
// RUN: triton_test_correctness %s --xla_gpu_experimental_enable_tiling_propagation

region {
  p0 = f32[] parameter(0)
  p1 = f32[] parameter(1)
  ROOT maximum.1 = f32[] maximum(p0, p1)
}

fusion {
  p = f32[8,4] parameter(0)
  c = f32[] constant(0)
  ROOT reduce = f32[8] reduce(p, c), dimensions={1},
    to_apply=region
}
// CHECK: %[[REDUCE_INPUT:.*]] = xtile.extract %{{.*}} :
// CHECK-SAME: memref<8x4xf32> -> tensor<4x4xf32>
// CHECK: "tt.reduce"(%[[REDUCE_INPUT]]) <{axis = 1 : i32}>
// CHECK: (tensor<4x4xf32>) -> tensor<4xf32>

ENTRY main {
  p = f32[8,4] parameter(0)
  ROOT fusion = f32[8] fusion(p), kind=kCustom,
    calls=fusion,
    backend_config={
      "fusion_backend_config":{
        "kind":"__triton",
        "block_level_fusion_config":{
          "output_tiles":[{"sizes":["4"]}],
          "num_warps":"1",
          "num_ctas":"1",
          "num_stages":"1"}}}
}
