// RUN: hlo_to_xtileir %s | FileCheck %s
// RUN: triton_test_correctness %s
// TODO: b/502910372 - enable when multi-output is supported.
// RUN-NOT: hlo_to_xtileir --use_experimental_tiling %s | FileCheck %s
// RUN-NOT: triton_test_correctness %s --xla_gpu_experimental_enable_tiling_propagation

region {
  p0 = f32[] parameter(0)
  p1 = f32[] parameter(1)
  ROOT maximum = f32[] maximum(p0, p1)
}

fusion {
  p = f32[128,512] parameter(0)
  abs = f32[128,512] abs(p)
  c = f32[] constant(-inf)
  reduce = f32[128] reduce(abs, c), dimensions={1}, to_apply=region
  ROOT tuple = (f32[128], f32[128,512]) tuple(reduce, abs)
}
// CHECK-COUNT-1:  xtile.extract
// CHECK:  %[[ABS:.*]] = math.absf
// CHECK: %[[REDUCE:.*]] = "tt.reduce"(%[[ABS:.*]]) <{axis = 1 : i32}>
// CHECK:  xtile.insert %[[REDUCE]] {{.*}} : tensor<64xf32>
// CHECK:  xtile.insert %[[ABS]] {{.*}} : tensor<64x512xf32>

ENTRY main {
  p = f32[128,512] parameter(0)
  ROOT fusion = (f32[128], f32[128,512]) fusion(p), kind=kCustom,
    calls=fusion,
    backend_config={
      "fusion_backend_config":{
        "kind":"__triton",
        "block_level_fusion_config":{
          "output_tiles":[{"sizes":["64"]},{"sizes":["64","512"]}],
          "num_warps":"2",
          "num_ctas":"1",
          "num_stages":"1"}}}
}
