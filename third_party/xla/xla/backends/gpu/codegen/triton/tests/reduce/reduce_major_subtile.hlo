// RUN: hlo_to_xtileir %s | FileCheck %s
// RUN: triton_test_correctness %s
// RUN: hlo_to_xtileir --use_experimental_tiling %s | FileCheck %s
// RUN: triton_test_correctness --xla_gpu_experimental_enable_tiling_propagation %s

maximum {
  p0 = f32[] parameter(0)
  p1 = f32[] parameter(1)
  ROOT minimum = f32[] minimum(p0, p1)
}

fusion {
  p = f32[5,3] parameter(0)
  c = f32[] constant(10)
  ROOT reduce = f32[3] reduce(p, c), dimensions={0}, to_apply=maximum
}

// Make sure input tile is masked with a neutral value.
// CHECK:  %[[LOAD:.*]] = xtile.extract
// CHECK:  %[[MASKED:.*]] = xtile.mask %[[LOAD]]
// CHECK:  "tt.reduce"(%[[MASKED]]) <{axis = 0 : i32}>
// CHECK:  ^bb0(%[[ARG2:.*]]: f32, %[[ARG3:.*]]: f32):
// CHECK:    %[[ACC:.*]] = arith.minimumf %[[ARG2]], %[[ARG3]] : f32
// CHECK:    tt.reduce.return %[[ACC]] : f32
// CHECK:  })

ENTRY main {
  p = f32[5,3] parameter(0)
  ROOT triton_reduction = f32[3] fusion(p), kind=kCustom,
    calls=fusion,
    backend_config={
      "fusion_backend_config":{
        "kind":"__triton",
        "block_level_fusion_config":{
          "output_tiles":[{"sizes":["4"]}],
          "num_warps":"1",
          "num_ctas":"1",
          "num_stages":"1"}}}
}
