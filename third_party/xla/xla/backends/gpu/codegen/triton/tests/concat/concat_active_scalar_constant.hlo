// RUN: hlo_to_xtileir --xla_gpu_experimental_enable_tiling_propagation=false %s 2>&1 | FileCheck %s
// RUN: hlo_to_xtileir --xla_gpu_experimental_enable_tiling_propagation %s 2>&1 | FileCheck %s

// CHECK:      xtile.entry_func @triton_fn
// CHECK:      %[[CST:.*]] = arith.constant dense<4.000000e+00> : tensor<2xf32>
// CHECK:      scf.if
// CHECK:      } else {
// CHECK-NEXT:   scf.yield %[[CST]] : tensor<2xf32>
// CHECK-NEXT: }

HloModule concat_active_scalar_constant, is_scheduled=true, entry_computation_layout={(f32[8]{0})->f32[9]{0}}

%fused_computation (param_0: f32[8]) -> f32[9] {
  %param_0 = f32[8]{0} parameter(0)
  %cst = f32[1]{0} constant({4.0})
  %concat = f32[9]{0} concatenate(%param_0, %cst), dimensions={0}
  ROOT %slice = f32[9]{0} slice(%concat), slice={[0:9]}
}

ENTRY %entry_computation (param_0: f32[8]) -> f32[9] {
  %param_0 = f32[8]{0} parameter(0)
  ROOT %fusion = f32[9]{0} fusion(%param_0), kind=kCustom, calls=%fused_computation,
    backend_config={
      "operation_queue_id":"0",
      "fusion_backend_config":{
        "kind":"__triton",
        "block_level_fusion_config":{
          "num_warps":"4",
          "output_tiles":[{"sizes":["2"]}],
          "num_ctas":1,
          "num_stages":1,
          "is_tma_allowed":true,
          "is_warp_specialization_allowed":false,
          "waves_per_eu":0
        }
      },
      "force_earliest_schedule":false,
      "reification_cost":[],
      "device_type":"DEVICE_TYPE_INVALID"
    }
}
