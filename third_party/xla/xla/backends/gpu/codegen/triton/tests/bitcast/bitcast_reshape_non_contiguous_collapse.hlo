// RUN: hlo_to_xtileir --xla_gpu_experimental_enable_tiling_propagation=false %s | FileCheck %s
// RUN: triton_test_correctness --xla_gpu_experimental_enable_tiling_propagation=false %s

// RUN: hlo_to_xtileir %s --xla_gpu_experimental_enable_tiling_propagation | FileCheck %s
// RUN: triton_test_correctness %s --xla_gpu_experimental_enable_tiling_propagation

fusion {
  p = f32[32]{0} parameter(0)
  bitcast = f32[8,4]{1,0} bitcast(p)
  ROOT slice = f32[4,1]{1,0} slice(bitcast), slice={[0:8:2], [0:1]}
}

// CHECK: #[[$MAP_0:.+]] = #xla.indexing_map<"([[PID:pid(_0)?]]) -> ([[PID]] * 16), domain: [[PID]] in [0, 1]">
// CHECK: #[[$MAP_1:.+]] = #xla.indexing_map<"([[PID]]) -> ([[PID]] * 2), domain: [[PID]] in [0, 1]">
// CHECK: xtile.entry_func @triton_fn(
// CHECK-SAME: %[[ARG0:.*]]: memref<32xf32>,
// CHECK-SAME: %[[ARG1:.*]]: memref<4x1xf32>,
// CHECK-SAME: %[[PID:.*]]: index)
// CHECK: %[[CONSTANT_0:.*]] = arith.constant 0 : index
// CHECK: %[[OFFSET_IN:.*]] = xla.apply_indexing #[[$MAP_0]](%[[PID]])
// CHECK: %[[EXTRACT:.*]] = xtile.extract %[[ARG0]][%[[OFFSET_IN]]] [2] [8] : memref<32xf32> -> tensor<2xf32>
// CHECK: %[[RESHAPE:.*]] = tt.reshape %[[EXTRACT]] : tensor<2xf32> -> tensor<2x1xf32>
// CHECK: %[[OFFSET_OUT:.*]] = xla.apply_indexing #[[$MAP_1]](%[[PID]])
// CHECK: xtile.insert %[[RESHAPE]] into %[[ARG1]][%[[OFFSET_OUT]], %[[CONSTANT_0]]] [2, 1] [1, 1] : tensor<2x1xf32> -> memref<4x1xf32>
// CHECK: xtile.return

ENTRY main {
  p = f32[32]{0} parameter(0)
  ROOT fusion = f32[4,1]{1,0} fusion(p), kind=kCustom, calls=fusion,
    backend_config={
    "fusion_backend_config":{
      "kind":"__triton",
      "block_level_fusion_config":{
        "output_tiles":[{"sizes":["2","1"]}],
        "num_warps":"1",
        "num_ctas":"1",
        "num_stages":"1"}}}
}