// RUN: hlo_to_xtileir %s | FileCheck %s
// RUN: triton_test_correctness %s

// Reproducer from b/380277401.
add {
  x = s32[] parameter(0)
  y = s32[] parameter(1)
  ROOT add = s32[] add(x, y)
}

fusion {
  p = s32[4,8] parameter(0)
  bitcast = s32[4,2,4] bitcast(p)
  zero = s32[] constant(0)
  reduce_1 = s32[4,2] reduce(bitcast, zero), dimensions={2}, to_apply=add
  ROOT reduce_2 = s32[2] reduce(reduce_1, zero), dimensions={0}, to_apply=add
}
// CHECK:     xtile.extract
// CHECK:     tt.reshape
// CHECK:     tt.reduce
// CHECK:     tt.reduce
// CHECK:     xtile.insert

ENTRY main {
  i = s32[32] iota(), iota_dimension=0
  p = s32[4,8] bitcast(i)

  ROOT r = s32[2] fusion(p), kind=kCustom, calls=fusion,
    backend_config={
      "fusion_backend_config":{
        "kind":"__triton",
        "block_level_fusion_config":{
          "output_tiles":[{"sizes":["2"]}],
          "num_warps":"1",
          "num_ctas":"1",
          "num_stages":"1"}}}
}
