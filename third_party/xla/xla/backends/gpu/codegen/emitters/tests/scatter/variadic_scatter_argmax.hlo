// RUN: fusion_to_mlir %s | emitters_opt -xla-test-optimize | FileCheck %s
// RUN: gpu_test_correctness %s --bijection_inputs=scatter:3

argmax_combiner {
  %curr_score     = f32[] parameter(0)
  %curr_agent     = s32[] parameter(1)
  %incoming_score = f32[] parameter(2)
  %incoming_agent = s32[] parameter(3)
  // Is incoming_score > curr_score?
  %is_higher = pred[] compare(%incoming_score, %curr_score), direction=GT
  // Select the winning score and winning agent ID
  %new_score = f32[] select(%is_higher, %incoming_score, %curr_score)
  %new_agent = s32[] select(%is_higher, %incoming_agent, %curr_agent)
  ROOT %result = (f32[], s32[]) tuple(%new_score, %new_agent)
}

fusion {
  %operand_1 = f32[50,5]  parameter(0)
  %operand_2 = s32[50,5]  parameter(1)
  %indices =  s32[24,1] iota(), iota_dimension=0
  %update_1 = f32[24,1,3] parameter(2)
  %update_2 = s32[24,1,3] parameter(3)

  ROOT %scatter = (f32[50,5], s32[50,5]) scatter(
      %operand_1, %operand_2, %indices, %update_1, %update_2),
    update_window_dims={1,2},
    inserted_window_dims={},
    scatter_dims_to_operand_dims={0},
    index_vector_dim=1,
    unique_indices=true,
    to_apply=argmax_combiner
}

// CHECK-LABEL: func.func @main(
// CHECK-SAME: %[[ARG0:.*]]: tensor<50x5xf32>{{.*}}%[[ARG1:.*]]: tensor<50x5xi32>{{.*}}%[[ARG2:.*]]: tensor<24x1x3xf32>{{.*}}%[[ARG3:.*]]: tensor<24x1x3xi32>{{.*}}%[[ARG4:.*]]: tensor<50x5xf32>{{.*}}%[[ARG5:.*]]: tensor<50x5xi32>{{.*}}) -> (tensor<50x5xf32>, tensor<50x5xi32>)
// CHECK:       %{{.*}}, %{{.*}} = xla.loop
// CHECK-SAME:    iter_args(%[[ITER1:.*]] = %[[ARG4]], %[[ITER2:.*]] = %[[ARG5]]) -> (tensor<50x5xf32>, tensor<50x5xi32>)
// CHECK:         %[[INS1:.*]] = tensor.insert %{{.*}} into %[[ITER1]][%{{.*}}, %{{.*}}] : tensor<50x5xf32>
// CHECK:         %[[INS2:.*]] = tensor.insert %{{.*}} into %[[ITER2]][%{{.*}}, %{{.*}}] : tensor<50x5xi32>
// CHECK:         xla.yield %[[INS1]], %[[INS2]] : tensor<50x5xf32>, tensor<50x5xi32>
// CHECK:       return %{{.*}}, %{{.*}} : tensor<50x5xf32>, tensor<50x5xi32>