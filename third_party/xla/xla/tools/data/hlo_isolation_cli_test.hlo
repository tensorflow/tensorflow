HloModule simple_fusion

%fused_computation (param_0: f32[2,2]) -> f32[2,2] {
  %p0 = f32[2,2]{1,0} parameter(0)
  ROOT %sine = f32[2,2]{1,0} sine(%p0)
}

ENTRY %entry_computation (param_0: f32[2,2]) -> f32[2,2] {
  %param_0 = f32[2,2]{1,0} parameter(0)
  ROOT %fusion = f32[2,2]{1,0} fusion(f32[2,2]{1,0} %param_0), kind=kLoop, calls=%fused_computation
}
