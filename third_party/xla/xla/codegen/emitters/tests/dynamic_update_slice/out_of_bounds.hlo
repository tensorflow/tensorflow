// RUN: gpu_fusion_to_mlir %s | emitters_opt -xla-test-optimize |\
// RUN:   FileCheck %s --check-prefixes=CHECK,CHECK-GPU
// RUN: cpu_fusion_to_mlir %s | emitters_opt -xla-test-optimize |\
// RUN:   FileCheck %s
// RUN: gpu_test_correctness %s --bijection_inputs=updated:1
// RUN: cpu_test_correctness %s --bijection_inputs=updated:1

fusion {
  in = f32[7,8] parameter(0)
  updates = f32[2,3] parameter(1)
  i0 = s32[] parameter(2)
  i1 = s32[] parameter(3)
  ROOT updated = f32[7,8] dynamic-update-slice(in, updates, i0, i1)
}

ENTRY main {
  %param_0 = f32[7,8] parameter(0)
  %param_1 = f32[2,3] parameter(1)
  %param_2 = s32[] parameter(2)
  %param_3 = s32[] parameter(3)
  ROOT %fusion = f32[7,8] fusion(%param_0, %param_1, %param_2, %param_3), kind=kLoop, calls=fusion
}

// CHECK:     func.func @main
// CHECK-SAME:  %arg0: tensor<7x8xf32>
// CHECK-SAME:  %arg1: tensor<2x3xf32>
// CHECK-SAME:  %arg2: tensor<i32>
// CHECK-SAME:  %arg3: tensor<i32>
// CHECK-GPU-SAME:  %arg4: tensor<7x8xf32>
// CHECK-DAG:   %[[C_5:.*]] = arith.constant 5
// CHECK-DAG:   %[[C_0:.*]] = arith.constant 0
// CHECK-GPU:   scf.forall (%[[WORKITEM_ID:.*]]) in (6)
// CHECK-GPU:     xla.loop
// CHECK-GPU-SAME:  -> (%[[RA:.*]], %[[RB:.*]]) in
// CHECK-GPU:       %[[I0:.*]] = xla.pure_call @fusion_i0
// CHECK-GPU:       %[[I1:.*]] = xla.pure_call @fusion_i1
// CHECK-GPU:       %[[IDX0:.*]] = arith.index_cast %[[I0]]
// CHECK-GPU:       %[[MIN0:.*]] = arith.minsi %[[IDX0]], %[[C_5]]
// CHECK-GPU:       %[[MAX0:.*]] = arith.maxsi %[[MIN0]], %[[C_0]]
// CHECK-GPU:       %[[ADD0:.*]] = arith.addi %[[RA]], %[[MAX0]]
// CHECK-GPU:       %[[IDX1:.*]] = arith.index_cast %[[I1]]
// CHECK-GPU:       %[[MIN1:.*]] = arith.minsi %[[IDX1]], %[[C_5]]
// CHECK-GPU:       %[[MAX1:.*]] = arith.maxsi %[[MIN1]], %[[C_0]]
// CHECK-GPU:       %[[ADD1:.*]] = arith.addi %[[RB]], %[[MAX1]]
// CHECK-GPU:       %[[UPDATE:.*]] = xla.pure_call @fusion_updates
// CHECK-GPU:       %[[INSERT:.*]] = tensor.insert %[[UPDATE:.*]] into %{{[a-z0-9]+}}[%[[ADD0]], %[[ADD1]]]
// CHECK-GPU:       xla.yield %[[INSERT]]