from collections.abc import Sequence
from typing import Self, overload

from typing_extensions import CapsuleType

from ._profile_data import ProfileData

class ProfilerServer:
  pass

def start_server(port: int) -> ProfilerServer: ...
def register_plugin_profiler(arg: CapsuleType, /) -> None: ...

class ProfilerSession:
  @overload
  def __init__(self) -> None: ...
  @overload
  def __init__(self, arg: ProfileOptions, /) -> None: ...
  def stop_and_export(self, arg: str, /) -> None: ...
  def stop(self) -> bytes: ...
  def stop_and_get_profile_data() -> ProfileData: ...
  def export(self, arg0: bytes, arg1: str, /) -> None: ...

class ProfileOptions:
  def __init__(self) -> None: ...
  @property
  def include_dataset_ops(self) -> bool: ...
  @include_dataset_ops.setter
  def include_dataset_ops(self, arg: bool, /) -> None: ...
  @property
  def host_tracer_level(self) -> int: ...
  @host_tracer_level.setter
  def host_tracer_level(self, arg: int, /) -> None: ...
  @property
  def python_tracer_level(self) -> int: ...
  @python_tracer_level.setter
  def python_tracer_level(self, arg: int, /) -> None: ...
  @property
  def enable_hlo_proto(self) -> bool: ...
  @enable_hlo_proto.setter
  def enable_hlo_proto(self, arg: bool, /) -> None: ...
  @property
  def start_timestamp_ns(self) -> int: ...
  @start_timestamp_ns.setter
  def start_timestamp_ns(self, arg: int, /) -> None: ...
  @property
  def duration_ms(self) -> int: ...
  @duration_ms.setter
  def duration_ms(self, arg: int, /) -> None: ...
  @property
  def raise_error_on_start_failure(self) -> bool: ...
  @raise_error_on_start_failure.setter
  def raise_error_on_start_failure(self, arg: bool, /) -> None: ...
  @property
  def advanced_configuration(self) -> dict: ...
  @advanced_configuration.setter
  def advanced_configuration(self, arg: dict, /) -> None: ...
  @property
  def repository_path(self) -> str: ...
  @repository_path.setter
  def repository_path(self, arg: str, /) -> None: ...
  @property
  def session_id(self) -> str: ...
  @session_id.setter
  def session_id(self, arg: str, /) -> None: ...

class TraceMe:
  def __init__(self, arg0: str, /, **kwargs) -> None: ...
  def __enter__(self) -> Self: ...
  def __exit__(self, *exc_info) -> None: ...
  def set_metadata(self, **kwargs) -> None: ...
  @staticmethod
  def is_enabled() -> bool: ...

def get_profiled_instructions_proto(tensorboard_dir: str) -> bytes: ...
def get_instructions_profile(
    tensorboard_dir: str,
) -> list[tuple[str, float]]: ...
@overload
def get_fdo_profile(arg0: bytes, arg1: bool, /) -> bytes: ...
@overload
def get_fdo_profile(arg: bytes, /) -> bytes: ...
def set_metadata(key: str, value: str) -> None: ...
def clear_metadata() -> None: ...
def aggregate_profiled_instructions(
    profiles: Sequence[bytes], percentile: int
) -> bytes: ...
