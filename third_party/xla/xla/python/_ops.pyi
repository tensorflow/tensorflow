class ShapeIndex:
  """Represents an XLA ShapeIndex.

  An index for specifying a particular nested subshape within a shape. Used in
  ShapeUtil::GetSubshape and other interfaces. ShapeIndex defines a path
  through
  the Shape tree where each element of ShapeIndex indexes into a tuple (or
  nested tuple) within the shape. For a non-nested tuple, an index has a
  single
  element.
  """

  def __init__(self, arg: Sequence[int], /) -> None: ...
  def __repr__(self) -> str: ...
  def __eq__(self, arg: ShapeIndex, /) -> bool: ...
  def __ne__(self, arg: ShapeIndex, /) -> bool: ...
  def __hash__(self) -> int: ...

class FftType(enum.Enum):
  FFT = 0

  IFFT = 1

  RFFT = 2

  IRFFT = 3

class PrecisionConfig_Precision(enum.Enum):
  DEFAULT = 0

  HIGH = 1

  HIGHEST = 2

class TriangularSolveOptions_Transpose(enum.Enum):
  TRANSPOSE_INVALID = 0

  NO_TRANSPOSE = 1

  TRANSPOSE = 2

  ADJOINT = 3

class RandomAlgorithm(enum.IntEnum):
  RNG_DEFAULT = 0

  RNG_THREE_FRY = 1

  RNG_PHILOX = 2

class ResultAccuracy_Mode(enum.Enum):
  DEFAULT = 0

  HIGHEST = 1

class CustomCallSchedule(enum.Enum):
  SCHEDULE_NONE = 0

  SCHEDULE_LATEST = 1

  SCHEDULE_EARLIEST = 2

class CustomCallApiVersion(enum.IntEnum):
  API_VERSION_ORIGINAL = 1

  API_VERSION_STATUS_RETURNING = 2

  API_VERSION_STATUS_RETURNING_UNIFIED = 3

  API_VERSION_TYPED_FFI = 4

