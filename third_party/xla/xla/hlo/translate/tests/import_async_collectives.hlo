// RUN: hlo-translate -hlo-to-mlir -split-input-file %s | FileCheck %s

// Tests for HLO async ops to validate HLO -> StableHLO conversion.

// CHECK-LABEL: module @main
// CHECK: stablehlo.async_start
// CHECK: stablehlo.all_gather
// CHECK: stablehlo.async_done
HloModule main, entry_computation_layout={(f32[4,2]{1,0})->f32[4,4]{1,0}}

ENTRY %main.1 (Arg_0.1: f32[4,2]) -> f32[4,4] {
  %Arg_0.1 = f32[4,2] parameter(0)
  %all-gather-start.1 = (f32[4,2], f32[4,4]) all-gather-start(%Arg_0.1), channel_id=1, replica_groups={{0,1},{2,3}}, dimensions={1}, use_global_device_ids=true
  ROOT %all-gather-done.1 = f32[4,4] all-gather-done(%all-gather-start.1)
}

// -----

// CHECK-LABEL: module @main
// CHECK: stablehlo.async_start
// CHECK: stablehlo.all_reduce
// CHECK: stablehlo.async_done
HloModule main, entry_computation_layout={(f32[4,2]{1,0})->f32[4,2]{1,0}}

%region_0.1 (Arg_0.2: f32[], Arg_1.1: f32[]) -> f32[] {
  %Arg_0.2 = f32[] parameter(0)
  %Arg_1.1 = f32[] parameter(1)
  ROOT %add.1 = f32[] add(%Arg_0.2, %Arg_1.1)
}

ENTRY %main.2 (Arg_0.3: f32[4,2]) -> f32[4,2] {
  %Arg_0.3 = f32[4,2] parameter(0)
  %all-reduce-start.1 = f32[4,2] all-reduce-start(%Arg_0.3), channel_id=1, replica_groups={{0,1},{2,3}}, use_global_device_ids=true, to_apply=%region_0.1
  ROOT %all-reduce-done.1 = f32[4,2] all-reduce-done(%all-reduce-start.1)
}

// -----

// CHECK-LABEL: module @main
// CHECK: stablehlo.async_start
// CHECK: stablehlo.all_to_all
// CHECK: stablehlo.async_done
HloModule main, entry_computation_layout={(f32[4,2]{1,0})->f32[4,2]{1,0}}

%region_0.1 (Arg_0.2: f32[4,2]) -> f32[4,2] {
  %Arg_0.2 = f32[4,2] parameter(0)
  ROOT %all-to-all.1 = f32[4,2] all-to-all(%Arg_0.2), channel_id=1, replica_groups={{0,1},{2,3}}, dimensions={1}
}

ENTRY %main.2 (Arg_0.3: f32[4,2]) -> f32[4,2] {
  %Arg_0.3 = f32[4,2] parameter(0)
  %async-start.1 = ((f32[4,2]), f32[4,2]) async-start(%Arg_0.3), calls=%region_0.1
  ROOT %async-done.1 = f32[4,2] async-done(%async-start.1)
}

// -----

// CHECK-LABEL: module @main
// CHECK: stablehlo.async_start
// CHECK: stablehlo.collective_permute
// CHECK: stablehlo.async_done
HloModule main, entry_computation_layout={(f32[4,2]{1,0})->f32[4,2]{1,0}}

ENTRY %main.1 (Arg_0.1: f32[4,2]) -> f32[4,2] {
  %Arg_0.1 = f32[4,2] parameter(0)
  %collective-permute-start.1 = (f32[4,2], f32[4,2]) collective-permute-start(%Arg_0.1), source_target_pairs={{0,1},{1,2},{2,3}}
  ROOT %collective-permute-done.1 = f32[4,2] collective-permute-done(%collective-permute-start.1)
}

// -----

// CHECK-LABEL: module @main
// CHECK: stablehlo.async_start
// CHECK: stablehlo.reduce_scatter
// CHECK: stablehlo.async_done
HloModule main, entry_computation_layout={(f32[4,2]{1,0})->f32[2,2]{1,0}}

%region_1.1 (Arg_0.3: f32[], Arg_1.1: f32[]) -> f32[] {
  %Arg_0.3 = f32[] parameter(0)
  %Arg_1.1 = f32[] parameter(1)
  ROOT %add.1 = f32[] add(%Arg_0.3, %Arg_1.1)
}

%region_0.2 (Arg_0.4: f32[4,2]) -> f32[2,2] {
  %Arg_0.4 = f32[4,2] parameter(0)
  ROOT %reduce-scatter.1 = f32[2,2] reduce-scatter(%Arg_0.4), channel_id=1, replica_groups={{0,1},{2,3}}, dimensions={0}, to_apply=%region_1.1
}

ENTRY %main.3 (Arg_0.5: f32[4,2]) -> f32[2,2] {
  %Arg_0.5 = f32[4,2] parameter(0)
  %async-start.1 = ((f32[4,2]), f32[2,2]) async-start(%Arg_0.5), calls=%region_0.2
  ROOT %async-done.1 = f32[2,2] async-done(%async-start.1)
}

// -----

// CHECK-LABEL: module @main
// CHECK: stablehlo.async_start
// CHECK: stablehlo.collective_broadcast
// CHECK: stablehlo.async_done
HloModule main, entry_computation_layout={(f32[4,2]{1,0})->f32[4,2]{1,0}}

%region_0.1 (Arg_0.2: f32[4,2]) -> f32[4,2] {
  %Arg_0.2 = f32[4,2] parameter(0)
  ROOT %collective-broadcast.1 = f32[4,2] collective-broadcast(%Arg_0.2), channel_id=1, replica_groups={{0,1},{2,3}}
}

ENTRY %main.2 (Arg_0.3: f32[4,2]) -> f32[4,2] {
  %Arg_0.3 = f32[4,2] parameter(0)
  %async-start.1 = ((f32[4,2]), f32[4,2]) async-start(%Arg_0.3), calls=%region_0.1
  ROOT %async-done.1 = f32[4,2] async-done(%async-start.1)
}
