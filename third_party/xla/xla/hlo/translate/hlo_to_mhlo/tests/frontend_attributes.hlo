HloModule frontend_attributes_map

map_comp {
  param0 = f32[] parameter(0)
  param1 = s32[] parameter(1)
  ROOT add = f32[] add(param0, param0)
}

// CHECK-LABEL: func.func @main
ENTRY main {
  operand0 = f32[4] parameter(0)
  operand1 = s32[4] parameter(1)
  // CHECK:      mhlo.map
  // CHECK:      mhlo.frontend_attributes = {
  // CHECK-DAG:    test_attr = "yes"
  // CHECK:      }
  ROOT map = f32[4] map(operand0, operand1), dimensions={0}, to_apply=map_comp, frontend_attributes={test_attr="yes"}
}

