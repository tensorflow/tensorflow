HloModule frontend_attributes_dynamic_update_slice

// CHECK-LABEL: func.func @main
ENTRY main {
  operand = f32[2,2] parameter(0)
  update = f32[1,1] parameter(1)
  idx = s32[] parameter(2)
  // CHECK:      mhlo.dynamic_update_slice
  // CHECK:      mhlo.frontend_attributes = {
  // CHECK-DAG:    test_attr = "yes"
  // CHECK:      }
  ROOT dus = f32[2,2] dynamic-update-slice(operand, update, idx, idx), frontend_attributes={test_attr="yes"}
}