HloModule frontend_attributes_dynamic_slice

// CHECK-LABEL: func.func @main
ENTRY main {
  operand = s32[1,4] parameter(0)
  idx0 = s32[] parameter(1)
  idx1 = s32[] parameter(2)
  // CHECK:      mhlo.dynamic_slice
  // CHECK:      mhlo.frontend_attributes = {
  // CHECK-DAG:    test_attr = "yes"
  // CHECK:      }
  ROOT ds = s32[1,2] dynamic-slice(operand, idx0, idx1), dynamic_slice_sizes={1,2}, frontend_attributes={test_attr="yes"}
}

