  // CHECK:      mhlo.concatenate
  // CHECK:      mhlo.frontend_attributes = {
  // CHECK-DAG:    test_attr = "yes"
  // CHECK:      }
  ROOT concatenate = f32[4,3] concatenate(operand0, operand1), dimensions={1}, frontend_attributes={test_attr="yes"}
}

