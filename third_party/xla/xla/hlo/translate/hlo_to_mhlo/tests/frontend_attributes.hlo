// RUN: xla-translate -hlo-text-to-mlir-hlo -split-input-file -hlo-flatten-computation-args-result=false %s -o - | FileCheck %s
// RUN: hlo-translate -hlo-to-mlir -split-input-file -emit-mhlo %s | FileCheck %s

HloModule frontend_attributes, entry_computation_layout={(f32[], f32[])->f32[]}

comp {
  param = f32[] parameter(0)
  ROOT negate = f32[] negate(param)
}

// CHECK-LABEL: func.func @main
// CHECK: %arg0: tensor<f32>,
// CHECK: %arg1: tensor<f32> {mhlo.frontend_attributes = {key = "value"}
ENTRY main {
  param = f32[] parameter(0)
  param1 = f32[] parameter(1), frontend_attributes={key="value"}
  // CHECK:      call @comp(%arg1) {mhlo.frontend_attributes = {k = "v"}}
  // CHECK:      mhlo.add
  // CHECK:      mhlo.frontend_attributes = {
  // CHECK-DAG:    _dummy_frontend_attribute = "xyz"
  // CHECK-DAG:    _xla_compute_type = "host"
  // CHECK:      }
  call = f32[] call(param1), to_apply=comp, frontend_attributes={k="v"}
  ROOT add = f32[] add(param, call), frontend_attributes={
    _xla_compute_type="host", _dummy_frontend_attribute="xyz"}
}

// -----

HloModule frontend_attributes, entry_computation_layout={(f32[], f32[])->f32[]}

comp {
  param = f32[] parameter(0)
  ROOT negate = f32[] negate(param)
}

// CHECK-LABEL: func.func @main
// CHECK: %arg0: tensor<f32>,
// CHECK: %arg1: tensor<f32> {mhlo.frontend_attributes = {key = "value"}
ENTRY main {
  param = f32[] parameter(0)
  param1 = f32[] parameter(1), frontend_attributes={key="value"}
  // CHECK:      call @comp(%arg1) {mhlo.frontend_attributes = {
  // CHECK-DAG: k = "v"
  // CHECK-DAG: backend_config = "{\22flag_configs\22:[]}"
  // CHECK: }}
  // CHECK:      mhlo.add
  // CHECK:      mhlo.frontend_attributes = {
  // CHECK-DAG:    _dummy_frontend_attribute = "xyz"
  // CHECK-DAG:    _xla_compute_type = "host"
  // CHECK:      }
  call = f32[] call(param1), to_apply=comp, frontend_attributes={k="v"}, backend_config={"flag_configs":[]}
  ROOT add = f32[] add(param, call), frontend_attributes={
    _xla_compute_type="host", _dummy_frontend_attribute="xyz"}
}

// -----

HloModule frontend_attributes_iota

// CHECK-LABEL: func.func @main
ENTRY main {
  // CHECK:      mhlo.iota
  // CHECK:      mhlo.frontend_attributes = {
  // CHECK-DAG:    test_attr = "yes"
  // CHECK:      }
  ROOT iota = f32[10] iota(), iota_dimension=0, frontend_attributes={test_attr="yes"}
}

// -----

HloModule frontend_attributes_pad

// CHECK-LABEL: func.func @main
ENTRY main {
  operand = f32[4] parameter(0)
  padding_val = f32[] parameter(1)
  // CHECK:      mhlo.pad
  // CHECK:      mhlo.frontend_attributes = {
  // CHECK-DAG:    test_attr = "yes"
  // CHECK:      }
  ROOT pad = f32[6] pad(operand, padding_val), padding=1_1_0, frontend_attributes={test_attr="yes"}
}

// -----

HloModule frontend_attributes_scan

add_comp {
  param0 = f32[] parameter(0)
  param1 = f32[] parameter(1)
  add = f32[] add(param0, param1)
  ROOT t = (f32[], f32[]) tuple(add, add)
}

// CHECK-LABEL: func.func @main
ENTRY main {
  operand = f32[10] parameter(0)
  init = f32[] parameter(1)
  // CHECK:      mhlo.scan
  // CHECK:      mhlo.frontend_attributes = {
  // CHECK-DAG:    test_attr = "yes"
  // CHECK:      }
  ROOT scan = (f32[10], f32[]) scan(operand, init), dimensions={0}, num_carries=1, is_associative=true, to_apply=add_comp, frontend_attributes={test_attr="yes"}
}

// -----

HloModule frontend_attributes_slice

// CHECK-LABEL: func.func @main
ENTRY main {
  operand = f32[10] parameter(0)
  // CHECK:      mhlo.slice
  // CHECK:      mhlo.frontend_attributes = {
  // CHECK-DAG:    test_attr = "yes"
  // CHECK:      }
  ROOT slice = f32[4] slice(operand), slice={[0:4:1]}, frontend_attributes={test_attr="yes"}
}

// -----

HloModule frontend_attributes_sort

compare {
  param0 = f32[] parameter(0)
  param1 = f32[] parameter(1)
  ROOT cmp = pred[] compare(param0, param1), direction=LT
}

// CHECK-LABEL: func.func @main
ENTRY main {
  operand = f32[10] parameter(0)
  // CHECK:      mhlo.sort
  // CHECK:      mhlo.frontend_attributes = {
  // CHECK-DAG:    test_attr = "yes"
  // CHECK:      }
  ROOT sort = f32[10] sort(operand), dimensions={0}, is_stable=true, to_apply=compare, frontend_attributes={test_attr="yes"}
}

