HloModule TestNormalDistribution

ENTRY test_normal_multidim_split {
  mean = f32[] constant(0)
  stdev = f32[] constant(1)
  shape = u64[3] constant({8, 4, 2})
  ROOT result = f32[2,2] rng(mean, stdev, shape), distribution=rng_normal
}

