// CHECK-LABEL: ENTRY %test_multi_device
// CHECK-NEXT:  %[[shape:[^ ]+]] = u64[3]{0} constant({2, 4, 8})
// CHECK-NEXT:  %[[constant:[^ ]+]] = u64[] constant(3668340012)
// CHECK-NEXT:  %[[rng_get_and_update_state:[^ ]+]] = u64[2]{0} rng-get-and-update-state(), delta=1
// CHECK-NEXT:  %[[min:[^ ]+]] = f32[] constant(0)
// CHECK-NEXT:  %[[max:[^ ]+]] = f32[] constant(1)
// CHECK-NEXT:  ROOT %[[call:[^ ]+]] = f32[] call(%[[constant]], %[[rng_get_and_update_state]], %[[min]], %[[max]]), to_apply=%[[$rng_1]]

HloModule TestMultiDevice, replica_count=2, num_partitions=2

ENTRY test_multi_device {
  min = f32[] constant(0)
  max = f32[] constant(1)
  shape = u64[3] constant({2, 4, 8})
  ROOT result = f32[] rng(min, max, shape), distribution=rng_uniform
}