HloModule TestNormalDistributionSmallFloat

ENTRY test_normal_small_float {
  mean = f16[] constant(0)
  stdev = f16[] constant(1)
  shape = f16[3] constant({8, 4, 2})
  ROOT result = f16[] rng(mean, stdev, shape), distribution=rng_normal
}

