+                          raggedDotDimNums.getRhsBatchingDimensions(),
+                          raggedDotDimNums.getLhsContractingDimensions(),
+                          raggedDotDimNums.getRhsContractingDimensions(),
+                          raggedDotDimNums.getLhsRaggedDimensions(),
