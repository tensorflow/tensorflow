+
+// CHECK-LABEL: vhlo.func_v1 @custom_call_explicit_empty
+func.func @custom_call_explicit_empty(%arg0: tensor<f32>) -> tensor<f32> {
+  // CHECK: vhlo.custom_call_v1
+  %0 = "stablehlo.custom_call"(%arg0) {
