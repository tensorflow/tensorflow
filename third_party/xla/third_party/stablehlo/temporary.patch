+// Helper to compute cot derivative coefficients
+static std::vector<double> getCotDerivativeCoefficients(int n) {
+  std::vector<double> coeffs = {0.0, 1.0};
+  for (int k = 1; k <= n; ++k) {
+    std::vector<double> next_coeffs(coeffs.size() + 2, 0.0);
+    for (size_t i = 1; i < coeffs.size(); ++i) {
+      double c = coeffs[i];
+      if (c == 0.0) continue;
+      next_coeffs[i - 1] += i * c;
+      next_coeffs[i + 1] += i * c;
+    }
+    coeffs = std::move(next_coeffs);
+  }
+  return coeffs;
+}
