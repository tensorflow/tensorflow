+func.func @custom_call_default(%arg0: tensor<f32>) -> tensor<f32> {
+  // CHECK: vhlo.custom_call_v1
+  %0 = "stablehlo.custom_call"(%arg0) {
+    call_target_name = "foo"
+  } : (tensor<f32>) -> tensor<f32>
+  func.return %0 : tensor<f32>
+}
