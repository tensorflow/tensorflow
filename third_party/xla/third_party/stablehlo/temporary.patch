-  const auto& fltSemantics = floatType.getFloatSemantics();
-  auto roundingMode = APFloat::rmNearestTiesToEven;
-  bool losesInfo;
-  apf.convert(fltSemantics, roundingMode, &losesInfo);
-  return apf;
