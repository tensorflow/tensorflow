-  // clang-format off
-  PRED,
-  I2, I4, I8, I16, I32, I64,
-  UI2, UI4, UI8, UI16, UI32, UI64,
-  BF16, F16, F32, F64,
-  F4E2M1FN, F6E2M3FN, F6E3M2FN, F8E3M4, F8E4M3,
-  F8E4M3FN, F8E4M3FNUZ, F8E4M3B11FNUZ, F8E5M2, F8E5M2FNUZ, F8E8M0FNU,
-  COMPLEXF32, COMPLEXF64
