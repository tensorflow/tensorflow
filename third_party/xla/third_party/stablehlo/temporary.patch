+  %result = "chlo.mulhi"(%lhs, %rhs) : (tensor<2xui16>, tensor<2xui16>) -> tensor<2xui16>
+  check.expect_eq_const %result, dense<[15, 1]> : tensor<2xui16>
+  func.return
