+  %result = "chlo.mulhi"(%lhs, %rhs) : (tensor<2xi16>, tensor<2xi16>) -> tensor<2xi16>
+  check.expect_eq_const %result, dense<[2, -2]> : tensor<2xi16>
+  func.return
+}
