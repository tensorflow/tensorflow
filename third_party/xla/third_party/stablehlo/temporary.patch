+  // are not used in StableHLO.
+  return type.isSignlessInteger() && !IsBoolean(elementType);
+}
+
+bool IsUnsignedInteger(ElementType elementType) {
+  MLIRContext ctx;
+  return getElementType(ctx, elementType).isUnsignedInteger() &&
