// RUN: tf-opt %s -tfl-quantize='qdq-conversion-mode=Strict' | FileCheck %s

// CHECK-LABEL: QuantizeConvDRQ
func.func @QuantizeConvDRQ(%arg0: tensor<1x28x28x3xf32>) -> (tensor<1x28x28x4xf32>) {
    %cst = arith.constant dense<0.000000e+00> : tensor<4xf32>
    %cst_0 = arith.constant dense<""> : tensor<4x3x3x3xf32>
    %0 = "tfl.quantize"(%cst_0) <{qtype = tensor<4x3x3x3x!quant.uniform<i8:f32:0, {0.029725207015872002,0.034746650606393814,0.035894367843866348,0.040518160909414291}>>}> : (tensor<4x3x3x3xf32>) -> tensor<4x3x3x3x!quant.uniform<i8:f32:0, {0.029725207015872002,0.034746650606393814,0.035894367843866348,0.040518160909414291}>>
    %1 = "tfl.dequantize"(%0) : (tensor<4x3x3x3x!quant.uniform<i8:f32:0, {0.029725207015872002,0.034746650606393814,0.035894367843866348,0.040518160909414291}>>) -> tensor<4x3x3x3xf32>
    %2 = "tfl.conv_2d"(%arg0, %1, %cst) <{dilation_h_factor = 1 : i32, dilation_w_factor = 1 : i32, fused_activation_function = "NONE", padding = "SAME", stride_h = 1 : i32, stride_w = 1 : i32}> : (tensor<1x28x28x3xf32>, tensor<4x3x3x3xf32>, tensor<4xf32>) -> tensor<1x28x28x4xf32>
    return %2 : tensor<1x28x28x4xf32>

// CHECK:   %[[VAL_1:.*]] = arith.constant dense<0.000000e+00> : tensor<4xf32>
// CHECK:   %[[VAL_2:.*]] = "tfl.pseudo_qconst"() <{qtype = tensor<4x3x3x3x!quant.uniform<i8:f32:0, {0.029725207015872002,0.034746650606393814,0.035894367843866348,0.040518160909414291}>>, value = dense<"0xCEDC95F6068C0141586A93BDC07FA5311F322C5FE660D0E7D2EBA6E64F10C039D2A2B26F9FCB1B90194D04097FE9B049FDFDE56EC5CB3B60BFF77F4FD008F2D22820CFF229E1E510CE035AC4FAF1CDA83235FD4022E72E0D3116E6F605391C16CBD5F89E1457722209D081BB"> : tensor<4x3x3x3xi8>}> : () -> tensor<4x3x3x3x!quant.uniform<i8:f32:0, {0.029725207015872002,0.034746650606393814,0.035894367843866348,0.040518160909414291}>>
// CHECK:   %[[VAL_3:.*]] = "tfl.conv_2d"(%arg0, %[[VAL_2]], %[[VAL_1]]) <{dilation_h_factor = 1 : i32, dilation_w_factor = 1 : i32, fused_activation_function = "NONE", padding = "SAME", stride_h = 1 : i32, stride_w = 1 : i32}> : (tensor<1x28x28x3xf32>, tensor<4x3x3x3x!quant.uniform<i8:f32:0, {0.029725207015872002,0.034746650606393814,0.035894367843866348,0.040518160909414291}>>, tensor<4xf32>) -> tensor<1x28x28x4xf32>
// CHECK:   return %[[VAL_3]] : tensor<1x28x28x4xf32>
}

// -----

func.func @QuantizeConvWithBiasDRQ(%arg0: tensor<1x28x28x3xf32>) -> (tensor<1x28x28x4xf32>) {
  %cst = arith.constant dense<[-0.354638785, 2.64603066, -1.39717865, 2.18649459]> : tensor<4xf32>
  %cst_0 = arith.constant dense<""> : tensor<4x3x3x3xf32>
  %0 = "tfl.quantize"(%cst_0) <{qtype = tensor<4x3x3x3x!quant.uniform<i8:f32:0, {0.029725207015872002,0.034746650606393814,0.035894367843866348,0.040518160909414291}>>}> : (tensor<4x3x3x3xf32>) -> tensor<4x3x3x3x!quant.uniform<i8:f32:0, {0.029725207015872002,0.034746650606393814,0.035894367843866348,0.040518160909414291}>>
  %1 = "tfl.dequantize"(%0) : (tensor<4x3x3x3x!quant.uniform<i8:f32:0, {0.029725207015872002,0.034746650606393814,0.035894367843866348,0.040518160909414291}>>) -> tensor<4x3x3x3xf32>
  %2 = "tfl.conv_2d"(%arg0, %1, %cst) <{dilation_h_factor = 1 : i32, dilation_w_factor = 1 : i32, fused_activation_function = "NONE", padding = "SAME", stride_h = 1 : i32, stride_w = 1 : i32}> : (tensor<1x28x28x3xf32>, tensor<4x3x3x3xf32>, tensor<4xf32>) -> tensor<1x28x28x4xf32>
  return %2 : tensor<1x28x28x4xf32>

// CHECK:   %[[VAL_1:.*]] = arith.constant dense<[-0.354638785, 2.64603066, -1.39717865, 2.18649459]> : tensor<4xf32>
// CHECK:   %[[VAL_2:.*]] = "tfl.pseudo_qconst"() <{qtype = tensor<4x3x3x3x!quant.uniform<i8:f32:0, {0.029725207015872002,0.034746650606393814,0.035894367843866348,0.040518160909414291}>>, value = dense<"0xCEDC95F6068C0141586A93BDC07FA5311F322C5FE660D0E7D2EBA6E64F10C039D2A2B26F9FCB1B90194D04097FE9B049FDFDE56EC5CB3B60BFF77F4FD008F2D22820CFF229E1E510CE035AC4FAF1CDA83235FD4022E72E0D3116E6F605391C16CBD5F89E1457722209D081BB"> : tensor<4x3x3x3xi8>}> : () -> tensor<4x3x3x3x!quant.uniform<i8:f32:0, {0.029725207015872002,0.034746650606393814,0.035894367843866348,0.040518160909414291}>>
// CHECK:   %[[VAL_3:.*]] = "tfl.conv_2d"(%arg0, %[[VAL_2]], %[[VAL_1]]) <{dilation_h_factor = 1 : i32, dilation_w_factor = 1 : i32, fused_activation_function = "NONE", padding = "SAME", stride_h = 1 : i32, stride_w = 1 : i32}> : (tensor<1x28x28x3xf32>, tensor<4x3x3x3x!quant.uniform<i8:f32:0, {0.029725207015872002,0.034746650606393814,0.035894367843866348,0.040518160909414291}>>, tensor<4xf32>) -> tensor<1x28x28x4xf32>
// CHECK:   return %[[VAL_3]] : tensor<1x28x28x4xf32>
}

// -----

func.func @QuantizeConvWithBiasAndReluDRQ(%arg0: tensor<1x28x28x3xf32>) -> (tensor<1x28x28x4xf32>) {
  %cst = arith.constant dense<[-0.354638785, 2.64603066, -1.39717865, 2.18649459]> : tensor<4xf32>
  %cst_0 = arith.constant dense<""> : tensor<4x3x3x3xf32>
  %0 = "tfl.quantize"(%cst_0) <{qtype = tensor<4x3x3x3x!quant.uniform<i8:f32:0, {0.029725207015872002,0.034746650606393814,0.035894367843866348,0.040518160909414291}>>}> : (tensor<4x3x3x3xf32>) -> tensor<4x3x3x3x!quant.uniform<i8:f32:0, {0.029725207015872002,0.034746650606393814,0.035894367843866348,0.040518160909414291}>>
  %1 = "tfl.dequantize"(%0) : (tensor<4x3x3x3x!quant.uniform<i8:f32:0, {0.029725207015872002,0.034746650606393814,0.035894367843866348,0.040518160909414291}>>) -> tensor<4x3x3x3xf32>
  %2 = "tfl.conv_2d"(%arg0, %1, %cst) <{dilation_h_factor = 1 : i32, dilation_w_factor = 1 : i32, fused_activation_function = "RELU", padding = "SAME", stride_h = 1 : i32, stride_w = 1 : i32}> : (tensor<1x28x28x3xf32>, tensor<4x3x3x3xf32>, tensor<4xf32>) -> tensor<1x28x28x4xf32>
  return %2 : tensor<1x28x28x4xf32>

// CHECK:   %[[VAL_1:.*]] = arith.constant dense<[-0.354638785, 2.64603066, -1.39717865, 2.18649459]> : tensor<4xf32>
// CHECK:   %[[VAL_2:.*]] = "tfl.pseudo_qconst"() <{qtype = tensor<4x3x3x3x!quant.uniform<i8:f32:0, {0.029725207015872002,0.034746650606393814,0.035894367843866348,0.040518160909414291}>>, value = dense<"0xCEDC95F6068C0141586A93BDC07FA5311F322C5FE660D0E7D2EBA6E64F10C039D2A2B26F9FCB1B90194D04097FE9B049FDFDE56EC5CB3B60BFF77F4FD008F2D22820CFF229E1E510CE035AC4FAF1CDA83235FD4022E72E0D3116E6F605391C16CBD5F89E1457722209D081BB"> : tensor<4x3x3x3xi8>}> : () -> tensor<4x3x3x3x!quant.uniform<i8:f32:0, {0.029725207015872002,0.034746650606393814,0.035894367843866348,0.040518160909414291}>>
// CHECK:   %[[VAL_3:.*]] = "tfl.conv_2d"(%arg0, %[[VAL_2]], %[[VAL_1]]) <{dilation_h_factor = 1 : i32, dilation_w_factor = 1 : i32, fused_activation_function = "RELU", padding = "SAME", stride_h = 1 : i32, stride_w = 1 : i32}> : (tensor<1x28x28x3xf32>, tensor<4x3x3x3x!quant.uniform<i8:f32:0, {0.029725207015872002,0.034746650606393814,0.035894367843866348,0.040518160909414291}>>, tensor<4xf32>) -> tensor<1x28x28x4xf32>
// CHECK:   return %[[VAL_3]] : tensor<1x28x28x4xf32>
}
